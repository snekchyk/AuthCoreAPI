generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model Users {
  id       String @id @default(uuid())
  name     String @unique
  password String
  email    String @unique
  age      Int
  role     Role   @default(BASIC)
}

enum Role {
  BASIC
  ADMIN
}
